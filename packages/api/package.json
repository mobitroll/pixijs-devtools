{
  "name": "@mobitroll/pixi-devtools",
  "publishConfig": {
    "access": "restricted"
  },
  "homepage": "https://github.com/mobitroll/pixijs-devtools#readme",
  "bugs": "https://github.com/mobitroll/pixijs-devtools/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/mobitroll/pixijs-devtools.git"
  },
  "license": "MIT",
  "version": "2.3.1",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "dist",
    "global.d.ts"
  ],
  "scripts": {
    "build": "vite build && tsc",
    "watch": "vite build --watch",
    "start": "npm run watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "launch-editor": "^2.6.0",
    "magic-string": "^0.30.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "pixi.js": "^8.14.3"
  },
  "peerDependencies": {
    "pixi.js": "^7 || ^8",
    "vite": "^4 || ^5 || ^6"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
